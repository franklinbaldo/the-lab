#!/usr/bin/env python3
"""lab-mail — MH mailbox backend for tools/lab mail commands.

Internal module called by tools/lab. Not invoked directly by personas.
"""

import email
import email.message
import mailbox
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

PERSONAS = sorted(p.parent.name for p in Path("lab").glob("*/SOUL.md"))
REPO = "franklinbaldo/rosencrantz-coin"
SESSION_FILE = ".lab_session"


def whoami():
    """Read logged-in persona from .lab_session (written by tools/lab login)."""
    p = Path(SESSION_FILE)
    if not p.exists():
        return None
    return p.read_text(encoding="utf-8").strip() or None


def today():
    return datetime.now(timezone.utc).strftime("%Y-%m-%d")



def get_mh(persona, box="inbox"):
    """Get or create an MH mailbox for a persona."""
    path = Path(f"lab/{persona}/mail/{box}")
    path.mkdir(parents=True, exist_ok=True)
    # Ensure .mh_sequences exists — Python's MH.set_sequences() opens it
    # with mode 'r+' which requires the file to already exist.
    seq_file = path / ".mh_sequences"
    if not seq_file.exists():
        seq_file.touch()
    return mailbox.MH(str(path), create=True)



def dedup_key(msg):
    """Create a deduplication key from message headers."""
    return f"{msg.get('From', '')}|{msg.get('Subject', '')}|{msg.get('Date', '')}"


# ── Persona commands ─────────────────────────────────────────────────────────


def cmd_list(me, _args):
    """List inbox messages with unseen markers."""

    inbox = get_mh(me, "inbox")
    keys = inbox.keys()

    if not keys:
        print(f"Inbox empty (lab/{me}/mail/inbox/)")
        inbox.close()
        return

    sequences = inbox.get_sequences()
    unseen = set(sequences.get("unseen", []))

    print(f"=== Inbox for {me} ({len(keys)} messages, {len(unseen)} unseen) ===\n")
    for key in sorted(keys):
        msg = inbox[key]
        marker = " *" if key in unseen else "  "
        sender = msg.get("From", "?")
        subject = msg.get("Subject", "(no subject)")
        date = msg.get("X-Lab-Date", msg.get("Date", "?"))
        replied = key in set(sequences.get("replied", []))
        r_marker = " [replied]" if replied else ""
        print(f"  {marker} #{key}  {sender:10s}  {subject}{r_marker}")

    inbox.close()
    print(f"\nRead: tools/lab-mail read <number>")


def cmd_read(me, args):
    """Read a message and mark as seen."""

    if not args:
        print("Usage: lab-mail read <message-number>")
        sys.exit(1)

    try:
        key = int(args[0])
    except ValueError:
        print(f"ERROR: '{args[0]}' is not a valid message number.")
        sys.exit(1)

    inbox = get_mh(me, "inbox")
    try:
        msg = inbox[key]
    except KeyError:
        print(f"ERROR: No message #{key} in inbox.")
        inbox.close()
        sys.exit(1)

    # Display
    print(f"From: {msg.get('From', '?')}")
    print(f"To: {msg.get('To', '?')}")
    print(f"Subject: {msg.get('Subject', '?')}")
    print(f"Date: {msg.get('Date', '?')}")
    print("---")
    print(msg.get_payload())

    # Mark as seen (remove from unseen sequence)
    sequences = inbox.get_sequences()
    unseen = set(sequences.get("unseen", []))
    if key in unseen:
        unseen.discard(key)
        sequences["unseen"] = sorted(unseen)
        inbox.set_sequences(sequences)

    inbox.flush()
    inbox.close()


def cmd_status(me, _args):
    """Show inbox/outbox summary."""

    inbox = get_mh(me, "inbox")
    outbox = get_mh(me, "outbox")

    inbox_keys = inbox.keys()
    outbox_keys = outbox.keys()
    sequences = inbox.get_sequences()
    unseen = len(sequences.get("unseen", []))

    print(f"=== Mail for {me} ===")
    print(f"  Inbox:  {len(inbox_keys)} ({unseen} unseen)")
    print(f"  Outbox: {len(outbox_keys)} queued")

    if unseen > 0:
        print(f"\n  Unseen:")
        for key in sequences.get("unseen", [])[:5]:
            msg = inbox[key]
            print(f"    #{key} from {msg.get('From', '?')}: {msg.get('Subject', '?')}")

    inbox.close()
    outbox.close()


# ── Heartbeat command (central delivery) ─────────────────────────────────────

def load_session_branches():
    """Load persona -> branch mapping from lab/sessions.json."""
    sessions_file = Path("lab/sessions.json")
    if not sessions_file.exists():
        return {}
    try:
        import json as _json
        data = _json.loads(sessions_file.read_text(encoding="utf-8"))
        return {p: info["branch"] for p, info in data.items() if info.get("branch")}
    except Exception:
        return {}


def cmd_deliver(_args):
    """Scan all persona branches and deliver outbox messages to inboxes on main.

    Called by the heartbeat workflow running on main.
    """
    print(f"=== Mail delivery — {today()} ===\n")

    branches = load_session_branches()
    if not branches:
        print("  (no sessions.json or no active branches)")
        return

    # Fetch all remote branches
    subprocess.run(
        ["git", "fetch", f"https://github.com/{REPO}.git",
         "+refs/heads/*:refs/remotes/lab/*"],
        capture_output=True,
    )

    total_delivered = 0

    for sender in PERSONAS:
        branch = branches.get(sender)
        if not branch:
            continue
        ref = f"lab/{branch}"

        # Check if branch exists
        result = subprocess.run(
            ["git", "rev-parse", "--verify", ref],
            capture_output=True,
        )
        if result.returncode != 0:
            continue

        # List files in sender's outbox
        outbox_path = f"lab/{sender}/mail/outbox"
        result = subprocess.run(
            ["git", "ls-tree", "--name-only", ref, f"{outbox_path}/"],
            capture_output=True, text=True,
        )
        if result.returncode != 0 or not result.stdout.strip():
            continue

        for filepath in result.stdout.strip().splitlines():
            filename = os.path.basename(filepath)
            if filename.startswith("."):
                continue

            # Read message content from branch
            cat_result = subprocess.run(
                ["git", "show", f"{ref}:{filepath}"],
                capture_output=True, text=True,
            )
            if cat_result.returncode != 0:
                continue

            content = cat_result.stdout

            # Parse email
            try:
                msg = email.message_from_string(content)
            except Exception:
                continue

            recipient = msg.get("To", "")
            if recipient not in PERSONAS or recipient == sender:
                continue

            # Open recipient's inbox and check for duplicates
            inbox = get_mh(recipient, "inbox")
            existing_keys = set()
            for k in inbox.keys():
                existing_keys.add(dedup_key(inbox[k]))

            msg_key = dedup_key(msg)
            if msg_key in existing_keys:
                inbox.close()
                continue

            # Deliver
            mh_msg = mailbox.MHMessage(content)
            new_key = inbox.add(mh_msg)

            # Add to unseen sequence
            sequences = inbox.get_sequences()
            unseen = list(sequences.get("unseen", []))
            unseen.append(new_key)
            sequences["unseen"] = sorted(unseen)
            inbox.set_sequences(sequences)

            inbox.flush()
            inbox.close()

            subject = msg.get("Subject", "(no subject)")
            print(f"  {sender} → {recipient}: {subject}")
            total_delivered += 1

    if total_delivered == 0:
        print("  (no new mail to deliver)")
    else:
        print(f"\n  {total_delivered} message(s) delivered")


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 2:
        print("Usage: tools/lab mail [list|read <num>|status|deliver]")
        sys.exit(1)

    cmd = sys.argv[1]

    # 'deliver' runs on main (no persona needed)
    if cmd == "deliver":
        cmd_deliver(sys.argv[2:])
        return

    persona_commands = {
        "list": cmd_list,
        "read": cmd_read,
        "status": cmd_status,
    }

    if cmd not in persona_commands:
        print(f"Unknown mail command: {cmd}")
        print(f"Available: {', '.join(persona_commands)}, deliver")
        sys.exit(1)

    me = whoami()
    if not me:
        print("ERROR: Not logged in. Run: tools/lab login <your-persona>")
        sys.exit(1)

    persona_commands[cmd](me, sys.argv[2:])


if __name__ == "__main__":
    main()
