---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import PersonaBadge from "../../components/PersonaBadge.astro";
import { getCollection, render } from "astro:content";

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const audits = await getCollection("audits");
  return audits.map((audit) => ({
    params: { slug: audit.id },
    props: { audit },
  }));
}

const { audit } = Astro.props;
const { Content } = await render(audit);
---

<Layout title={audit.data.title}>
  <Breadcrumb crumbs={[
    { label: "Home", href: base },
    { label: "Audits", href: `${base}audits/` },
    { label: audit.data.title },
  ]} />
  <article class="post">
    <header class="post__header">
      <h1>{audit.data.title}</h1>
      <div class="post__meta">
        <PersonaBadge persona="mycroft" />
        {audit.data.date && (
          <time datetime={audit.data.date.toISOString()}>
            {audit.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        )}
      </div>
    </header>
    <div class="post__body prose">
      <Content />
    </div>
  </article>
</Layout>
