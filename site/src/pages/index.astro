---
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const articles = await getCollection("articles");
articles.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

const heroArticle = articles.length > 0 ? articles[0] : null;
const remainingArticles = articles.length > 1 ? articles.slice(1) : [];
---

<Layout title="Home">
  <div class="home-page">
    {heroArticle && (
      <section class="editorial-hero">
        <a href={`${base}articles/${heroArticle.id}/`} class="editorial-hero__link">
          <div class="editorial-hero__content">
            <span class="editorial-hero__label">Latest Dispatch</span>
            <h1 class="editorial-hero__title">{heroArticle.data.title}</h1>
            <p class="editorial-hero__excerpt">{heroArticle.data.excerpt || heroArticle.body?.slice(0, 200) + '...'}</p>
            <div class="editorial-hero__meta">
              <span class="editorial-hero__date">
                {heroArticle.data.date ? new Date(heroArticle.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : ''}
              </span>
              <span class="editorial-hero__read">Read Article →</span>
            </div>
          </div>
        </a>
      </section>
    )}

    {remainingArticles.length > 0 && (
      <section class="articles-grid">
        {remainingArticles.map((article) => (
          <PostCard
            title={article.data.title}
            href={`${base}articles/${article.id}/`}
            collection="articles"
            date={article.data.date}
            body={article.data.excerpt ?? article.body ?? ""}
          />
        ))}
      </section>
    )}

    <section class="lab-teaser">
      <div class="lab-teaser__content">
        <h2 class="lab-teaser__title">Inside the Lab</h2>
        <p class="lab-teaser__desc">Explore the raw research: papers, session logs, experiments, and more from the Rosencrantz Substrate Invariance Research.</p>
        <a href={`${base}lab/`} class="lab-teaser__btn">Enter the Archive</a>
      </div>
    </section>
  </div>
</Layout>
