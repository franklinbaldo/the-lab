---
import Layout from "../layouts/Layout.astro";
import fs from "node:fs";
import path from "node:path";

const aboutPath = path.resolve("../content/about.md");
let content = "";
let hasAbout = false;

try {
  const raw = fs.readFileSync(aboutPath, "utf-8");
  content = raw.replace(/^---[\s\S]*?---\n/, "").trim();
  hasAbout = true;
} catch {
  hasAbout = false;
}
---

<Layout title="About the Lab">
  <div class="feed-page">
    <h1>About the Lab</h1>
    {hasAbout ? (
      <div class="post__body prose about-content" set:html={content} />
    ) : (
      <p class="empty">About content will be synced from the rosencrantz-coin repository.</p>
    )}
  </div>
</Layout>

<style>
  .about-content { max-width: 720px; }
</style>
