---
import PersonaBadge from "./PersonaBadge.astro";
import StatusBadge from "./StatusBadge.astro";
import { collectionLabels, excerpt, getPersona } from "../lib/utils";

interface Props {
  title: string;
  href: string;
  persona?: string;
  collection: string;
  date?: Date;
  status?: string;
  body?: string;
}

const { title, href, persona, collection, date, status, body } = Astro.props;
const p = getPersona(persona);
const typeLabel = collectionLabels[collection] ?? collection;
const excerptText = body ? excerpt(body) : "";
---

<article class="post-card" style={`--persona-color: ${p.color}`}>
  <a href={href} class="post-card__link">
    <div class="post-card__meta">
      <span class="post-card__type">{typeLabel}</span>
      <PersonaBadge persona={persona} />
      <StatusBadge status={status} />
      {date && (
        <time class="post-card__date" datetime={date.toISOString()}>
          {date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
        </time>
      )}
    </div>
    <h3 class="post-card__title">{title}</h3>
    {excerptText && <p class="post-card__excerpt">{excerptText}</p>}
  </a>
</article>
